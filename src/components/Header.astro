---
import Hr from "./Hr.astro";
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { translateFor, getRelativeLocalePath } from "@/i18n/utils";
import { DEFAULT_LOCALE } from "@/i18n/config";
import LanguagePicker from "./LanguagePicker.astro";

const { pathname } = Astro.url;

const currentLocale = Astro.currentLocale;

const t = translateFor(currentLocale);

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  let normalizedPath = currentPath;
  if (currentLocale && currentLocale !== DEFAULT_LOCALE) {
    const localePrefix = `/${currentLocale}`;
    if (normalizedPath.startsWith(localePrefix)) {
      normalizedPath = normalizedPath.slice(localePrefix.length) || "/";
    }
  }

  const currentPathArray = normalizedPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return normalizedPath === path || currentPathArray[0] === pathArray[0];
};

const navLinks = [
  { path: "/posts/", key: "posts" as const },
  { path: "/tags/", key: "tags" as const },
  { path: "/about", key: "about" as const },
  { path: "/videos", key: "videos" as const },
];
---

<header>
  <a
    id="skip-to-content"
    href="#main-content"
    class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
  >
    {t("a11y.skipToContent")}
  </a>
  <div id="nav-container" class="mx-auto max-w-app">
    <div
      id="top-nav-wrap"
      class="relative flex items-center justify-between bg-background px-4 py-4 lg:py-6"
    >
      <a
        href={getRelativeLocalePath(currentLocale, "/")}
        class="shrink-0 text-xl font-semibold whitespace-nowrap lg:text-2xl"
      >
        {t("site.title")}
      </a>

      <nav id="nav-menu" class="flex items-center">
        <button
          id="menu-btn"
          class="focus-outline p-2 lg:hidden"
          aria-label={t("a11y.openMenu")}
          aria-expanded="false"
          aria-controls="menu-items"
          data-open-text={t("a11y.openMenu")}
          data-close-text={t("a11y.closeMenu")}
        >
          <IconX id="close-icon" class="hidden" />
          <IconMenuDeep id="menu-icon" />
        </button>

        <ul
          id="menu-items"
          class:list={[
            "absolute top-full right-0 left-0 z-40 grid w-full grid-cols-3 place-content-center gap-2 border-t border-border bg-background px-4 py-4 shadow-lg",
            "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:whitespace-nowrap hover:[&>li>a]:text-accent",
            "hidden",
            "lg:static lg:z-auto lg:mt-0 lg:flex lg:w-auto lg:items-center lg:gap-x-5 lg:border-t-0 lg:bg-transparent lg:px-0 lg:py-0 lg:shadow-none lg:[&>li>a]:px-2 lg:[&>li>a]:py-1",
          ]}
        >
          {
            navLinks.map(({ path, key }) => (
              <li class="col-span-3 lg:col-span-1">
                <a
                  href={getRelativeLocalePath(Astro.currentLocale, path)}
                  class:list={{
                    "active-nav": isActive(path.replace(/\/$/, "")),
                  }}
                >
                  {t(key)}
                </a>
              </li>
            ))
          }
          {
            SITE.showArchives && (
              <li class="col-span-3 lg:col-span-1">
                <LinkButton
                  href="/archives"
                  class:list={[
                    "focus-outline flex justify-center p-3 lg:p-1",
                    {
                      "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                    },
                  ]}
                  ariaLabel={t("a11y.archives")}
                  title={`   ${t("archives")}`}
                >
                  <IconArchive class="hidden lg:inline-block" />
                  <span class="lg:sr-only">{t("archives")}</span>
                </LinkButton>
              </li>
            )
          }
          <li class="col-span-1 flex items-center justify-center">
            <LinkButton
              href="/search"
              class:list={[
                "focus-outline flex p-3 lg:p-1",
                { "[&>svg]:stroke-accent": isActive("/search") },
              ]}
              ariaLabel={t("a11y.search")}
              title={` ${t("search")}`}
            >
              <IconSearch />
              <span class="sr-only">{t("search")}</span>
            </LinkButton>
          </li>
          <li class="col-span-1 flex items-center justify-center">
            <LanguagePicker />
          </li>
          {
            SITE.lightAndDarkMode && (
              <li class="col-span-1 flex items-center justify-center">
                <button
                  id="theme-btn"
                  class="focus-outline relative size-12 p-4 lg:size-8 hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
  <Hr />
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn") as HTMLButtonElement;
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");
    const openText = menuBtn?.dataset.openText || "Open Menu";
    const closeText = menuBtn?.dataset.closeText || "Close Menu";

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? openText : closeText);

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
