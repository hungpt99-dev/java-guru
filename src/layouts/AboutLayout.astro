---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { translateFor } from "@/i18n/utils";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const t = translateFor(Astro.currentLocale);

const { frontmatter } = Astro.props;

const siteTitle = t("site.title");
const pageTitle = t("about");
const title = `${pageTitle.charAt(0).toUpperCase() + pageTitle.slice(1)} | ${siteTitle}`;
---

<Layout title={title}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="mx-auto w-full max-w-app px-4 pb-12">
    <h1 class="inline-block text-2xl font-bold text-accent sm:text-3xl">
      {frontmatter.title}
    </h1>
    <article id="about" class="prose mt-8 max-w-3xl">
      <slot />
    </article>
  </main>
  <Footer />
</Layout>
