---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { DEFAULT_LOCALE, SUPPORTED_LOCALES } from "@/i18n/config";
import { translateFor } from "@/i18n/utils";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import { videos } from "@/data/videos";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map(locale => ({
    params: { locale: locale === DEFAULT_LOCALE ? undefined : locale },
  }));
}

const { locale = DEFAULT_LOCALE } = Astro.params;

const t = translateFor(Astro.currentLocale);

const localeVideos = videos.filter(v => v.locale === locale);
---

<Layout title={`${t("videos")} | ${t("site.title")}`}>
  <Header />
  <Main pageTitle={t("videos")} pageDesc={t("videos.desc")}>
    {
      localeVideos.length === 0 ? (
        <p class="text-foreground/60 text-center">{t("pageNotFound")}</p>
      ) : (
        <div class="flex flex-col gap-8">
          {localeVideos.map(video => (
            <div>
              <h2 class="text-accent mb-2 text-xl font-bold">{video.title}</h2>
              <p class="text-foreground/80 mb-4">{video.description}</p>
              <iframe
                src={`https://www.youtube.com/embed/${video.youtubeId}`}
                title={video.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          ))}
        </div>
      )
    }
  </Main>
  <Footer />
</Layout>
